# ═══════════════════════════════════════════════
# AlphaCouncil — Environment Configuration
# ═══════════════════════════════════════════════

# ─── Database (required) ──────────────────────
DATABASE_URL=postgresql://mantle:memorygraph@localhost:5432/memorygraph

# Password used by docker-compose.prod.yml for the PostgreSQL container
DB_PASSWORD=memorygraph

# ─── Mantle RPC (has default) ─────────────────
ALPHACOUNCIL_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz

# ─── LLM Provider (pick one) ──────────────────
# Options: mock | groq | gemini | openrouter | openai | ollama
LLM_PROVIDER=mock

# API key for the chosen provider (not needed for mock or ollama)
# Groq:     https://console.groq.com/keys (free, no credit card)
# Gemini:   https://aistudio.google.com/app/apikey (free, no credit card)
# OpenRouter: https://openrouter.ai/ (has free models)
# OpenAI:   https://platform.openai.com/ (paid)
LLM_API_KEY=

# Optional: override default model for the provider
# Groq:     llama-3.1-8b-instant (default) | llama-3.3-70b-versatile | llama-4-scout-17b-16e-instruct
# Gemini:   gemini-2.0-flash-lite (default) | gemini-2.0-flash
# Ollama:   llama3.1 (default) | mistral | phi3 | qwen2.5
#LLM_MODEL=

# Ollama host (only needed for ollama provider)
OLLAMA_HOST=http://localhost:11434

# ─── Telegram Bot (optional) ──────────────────
TELEGRAM_BOT_TOKEN=

# ─── Blockchain (optional — for on-chain anchoring) ──
# Private key without 0x prefix. Used to deploy contracts and write hashes.
PRIVATE_KEY=

# Contract addresses (filled after deployment)
OBSERVATION_REGISTRY_ADDRESS=
MEMORY_ANCHOR_ADDRESS=
AGENT_REGISTRY_ADDRESS=
